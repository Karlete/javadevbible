# Normalize all text files to LF in the repo. `text=auto` keeps Git's
# content-normalization on commit; the explicit `eol=lf` rules also force LF
# in the working tree, so Windows checkouts stop emitting
# "LF will be replaced by CRLF" warnings and diffs stay clean.
* text=auto

*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
