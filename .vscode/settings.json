{
  // This site is hand-formatted so that a small edit produces a small diff.
  // A formatter (Prettier or the built-in one) reflowing a whole file turns a
  // 2-line change into a 70-line diff — which is exactly what makes reviewing
  // "what actually changed" unreliable before a push to main. Keep saves
  // non-destructive; format manually only when you mean to.
  "editor.formatOnSave": false,
  "files.eol": "\n",
  "files.insertFinalNewline": false,
  "files.trimTrailingWhitespace": false
}
